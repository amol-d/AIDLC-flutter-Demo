# --- OS / IDE ---
.DS_Store
.idea/
*.iml
*.swp
.vscode/settings.json
.history/

# --- FVM (commit .fvmrc, never the SDK cache) ---
.fvm/

# --- Dart / Flutter ---
.dart_tool/
.packages
build/
coverage/
doc/api/
.flutter-plugins
.flutter-plugins-dependencies
*.log

# Keep pubspec.lock for apps (reproducible builds); packages resolve via melos
# (intentionally NOT ignoring pubspec.lock)

# --- Generated code (regenerate with: dart run melos run gen) ---
*.g.dart
*.freezed.dart
*.gr.dart
*.config.dart
package/shared/lib/src/generated/

# --- Android ---
**/android/.gradle/
**/android/local.properties
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
**/android/key.properties
**/*.keystore
**/*.jks

# --- iOS ---
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/ephemeral/
**/ios/Flutter/flutter_export_environment.sh
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/Flutter.podspec
**/ios/ServiceDefinitions.json
**/ios/Runner.xcworkspace/xcuserdata/
**/xcuserdata/

# --- Web ---
# (web build output covered by build/)

# --- Secrets / local env ---
*.env
!*.env.example
**/google-services.json
**/GoogleService-Info.plist
firebase-service-account*.json

# --- Melos ---
.melos_packages
pubspec_overrides.yaml
